{
  "name": "vue-prince",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/vue-prince.umd.js",
  "module": "./dist/vue-prince.es.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vue-prince.es.js",
      "require": "./dist/vue-prince.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --project tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "pinia": "^2.0.0",
    "vue": "^3.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "@vue/test-utils": "^2.4.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^25.0.0",
    "pinia": "^2.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0",
    "vue-tsc": "^3.2.6"
  }
}
